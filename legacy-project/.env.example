PORT=3000
HOST=0.0.0.0
FRONTEND_MODE=react

# 允许访问代理的前端域名。
# 本地调试可用 *，正式上线建议填你的 Vercel 域名或自定义域名。
CORS_ALLOW_ORIGIN=https://your-vercel-domain.vercel.app

# 登录页密码。前端登录后会通过 HttpOnly Cookie 保持会话。
APP_LOGIN_PASSWORD=please-change-me

# 智谱真实链路必填。用于：
# 1. 上传样本文件
# 2. 创建 glm-tts-clone 音色
# 3. 使用 glm-tts 生成真实语音
ZHIPU_API_KEY=

# 创意创作真实链路必填。用于调用豆包多模态 Responses API。
ARK_API_KEY=

# 阿里云真实链路必填。用于：
# 1. 上传样本后创建真实音色
# 2. 使用已创建音色生成真实语音
ALIYUN_API_KEY=

# 火山引擎真实链路需要的密钥。
# 当前项目里智谱和阿里云都已经接通到真实后端，
# 火山引擎接口仍然保留，后续可继续补齐真实联调验证。
VOLCENGINE_APP_KEY=
VOLCENGINE_ACCESS_KEY=

# 火山引擎真实链路常用的 speaker_id。
# 若未配置，前端也可以继续传入当前选择的 speaker_id。
VOLCENGINE_SPEAKER_ID=

# 本地最小链路兜底开关。开启后，声音克隆和语音生成会走本地 mock，
# 不再依赖第三方语音服务，但前后端调用链仍然完整可联调。
VOICE_CLONE_MOCK_MODE=false
