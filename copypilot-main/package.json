{
  "name": "copypilot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "vite build",
    "postbuild": "node scripts/generate-seo-pages.mjs",
    "preview": "vite preview --host 127.0.0.1",
    "cf:dev": "wrangler pages dev dist --compatibility-date=2026-05-09",
    "cf:deploy": "wrangler pages deploy dist",
    "cf:deploy:local": "powershell -ExecutionPolicy Bypass -File scripts/deploy-cloudflare.ps1"
  },
  "dependencies": {
    "@vitejs/plugin-vue": "^6.0.1",
    "lucide-vue-next": "^1.0.0",
    "vite": "^7.1.12",
    "vue": "^3.5.22"
  },
  "devDependencies": {
    "wrangler": "^4.44.0"
  }
}
